{%- liquid
	if customer
  	assign profile_link = routes.account_url
		assign profile_text = 'sections.header.my_account' | t
	else
  	assign profile_link = routes.account_login_url
		assign profile_text = 'sections.header.login' | t
	endif
-%}

{% comment %} BIRSE-CUSTOMIZE-start {% endcomment %}

<script type="module">
(function () {
	window.addEventListener('load', () => {
		let count=0;
		const interval = setInterval(() => {
			if (window.customElements && window.customElements.get('birse-wishlist-button')) {
				const searchIcon=document.querySelector('.thb-quick-search');
				const birseWishlistButton=document.querySelector('birse-wishlist-button[data-block-id]');
				const birseImageSearchButton=document.querySelector('birse-img-upload-button[data-block-id]:not(.float):not(.input-bar)')
				if(searchIcon && birseWishlistButton && birseImageSearchButton){
					searchIcon.after(birseWishlistButton);
					searchIcon.after(birseImageSearchButton);
					clearInterval(interval);
				}
				else{
					count++;
					if(count>50){
						clearInterval(interval);
					}
				}
			}
		},100)
	})
})();
</script>

{% comment %} BIRSE-CUSTOMIZE-end {% endcomment %}




<div class="thb-secondary-area thb-header-right">
	{%- unless header_settings.style == 'style4' -%}
	<div class="no-js-hidden">
		{%- render 'localization', id: 'HeaderLocalization', show_language_switcher: header_settings.show_language_switcher, show_currency_switcher: header_settings.show_currency_switcher, class: 'inside-header' -%}
	</div>
	{%- endunless -%}
	{%- if shop.customer_accounts_enabled -%}
    <a class="thb-secondary-area-item thb-secondary-myaccount" href="{{ profile_link | escape }}" title="{{ 'sections.header.my_account' | t }}"><span>{{ profile_text }}</span></a>
  {%- endif -%}
	<a class="thb-secondary-area-item thb-quick-search" href="{{ routes.search_url }}" title="{{ 'sections.header.search' | t }}">{%- render 'svg-icons' with 'search' -%}</a>
	<a class="thb-secondary-area-item thb-secondary-cart" href="{{ routes.cart_url }}" id="cart-drawer-toggle"><div class="thb-secondary-item-icon">{%- render 'svg-icons' with 'cart' %} <span class="thb-item-count">{%- if cart.item_count > 99 -%}{%- render 'svg-icons' with 'thb-asterisk' -%}{%- else -%}{{ cart.item_count }}{%- endif -%}</span></div></a>
</div>
